# Snyk (https://snyk.io) policy file, patches or ignores known vulnerabilities.
version: v1.25.0
ignore:
  snyk:lic:nuget:cortex.mediator:Unknown:
    - "*":
        reason: Verified Apache License 2.0
  snyk:lic:nuget:lll.durabletask.client:Unknown:
    - "*":
        reason: Verified MIT License
  snyk:lic:nuget:lll.durabletask.core:Unknown:
    - "*":
        reason: Verified MIT License
  snyk:lic:nuget:lll.durabletask.efcore:Unknown:
    - "*":
        reason: Verified MIT License
  snyk:lic:nuget:lll.durabletask.efcore.inmemory:Unknown:
    - "*":
        reason: Verified MIT License
  snyk:lic:nuget:lll.durabletask.efcore.sqlserver:Unknown:
    - "*":
        reason: Verified MIT License
  snyk:lic:nuget:lll.durabletask.worker:Unknown:
    - "*":
        reason: Verified MIT License
  snyk:lic:nuget:lll.durabletask.api:Unknown:
    - "*":
        reason: Verified MIT License
  snyk:lic:nuget:lll.durabletask.ui:Unknown:
    - "*":
        reason: Verified MIT License

patch: {}
exclude:
  global:
    - tests/**
